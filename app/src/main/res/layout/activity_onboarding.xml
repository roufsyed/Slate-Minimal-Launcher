<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:id="@+id/onboardingRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="32dp"
        android:paddingTop="80dp"
        android:paddingBottom="32dp"
        android:gravity="center_horizontal">

        <!-- ── Branding ── -->

        <TextView
            android:id="@+id/labelAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="slate"
            android:textSize="56sp"
            android:textColor="#FFFFFF"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="-0.03" />

        <TextView
            android:id="@+id/labelTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="a minimal launcher"
            android:textSize="15sp"
            android:textColor="#666666"
            android:letterSpacing="0.05" />

        <!-- ── Theme selection ── -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:layout_marginBottom="16dp"
            android:text="CHOOSE A THEME"
            android:textSize="11sp"
            android:textColor="#555555"
            android:textAllCaps="true"
            android:letterSpacing="0.15"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <!-- Dark theme card -->
            <LinearLayout
                android:id="@+id/cardDark"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:orientation="vertical"
                android:padding="20dp"
                android:minHeight="200dp">

                <TextView
                    android:id="@+id/labelDark"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DARK"
                    android:textSize="11sp"
                    android:textColor="#8888FF"
                    android:textAllCaps="true"
                    android:letterSpacing="0.15"
                    android:textStyle="bold"
                    android:layout_marginBottom="24dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="messages"
                    android:textSize="20sp"
                    android:textColor="#808080" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="maps"
                    android:textSize="16sp"
                    android:textColor="#808080"
                    android:layout_marginTop="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="camera"
                    android:textSize="14sp"
                    android:textColor="#808080"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="photos"
                    android:textSize="13sp"
                    android:textColor="#808080"
                    android:layout_marginTop="7dp" />

            </LinearLayout>

            <!-- Light theme card -->
            <LinearLayout
                android:id="@+id/cardLight"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:orientation="vertical"
                android:padding="20dp"
                android:minHeight="200dp">

                <TextView
                    android:id="@+id/labelLight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LIGHT"
                    android:textSize="11sp"
                    android:textColor="#333399"
                    android:textAllCaps="true"
                    android:letterSpacing="0.15"
                    android:textStyle="bold"
                    android:layout_marginBottom="24dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="messages"
                    android:textSize="20sp"
                    android:textColor="#333333" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="maps"
                    android:textSize="16sp"
                    android:textColor="#333333"
                    android:layout_marginTop="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="camera"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="photos"
                    android:textSize="13sp"
                    android:textColor="#333333"
                    android:layout_marginTop="7dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- ── Spacer ── -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- ── Actions ── -->

        <TextView
            android:id="@+id/btnSetDefault"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="Set as default launcher"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:paddingVertical="16dp"
            android:background="@android:color/transparent" />

        <TextView
            android:id="@+id/btnSkip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Skip for now"
            android:textSize="14sp"
            android:textColor="#555555"
            android:gravity="center"
            android:paddingVertical="14dp" />

        <!-- ── Returning user ── -->

        <View
            android:layout_width="48dp"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="#222222" />

        <TextView
            android:id="@+id/btnImportSettings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Import previous settings"
            android:textSize="14sp"
            android:textColor="#8888FF"
            android:gravity="center"
            android:paddingVertical="12dp" />

        <TextView
            android:id="@+id/labelImportHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Restore from a slate_backup.json file"
            android:textSize="12sp"
            android:textColor="#444444"
            android:gravity="center" />

        <TextView
            android:id="@+id/btnPrivacyPolicy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Privacy Policy"
            android:textSize="12sp"
            android:textColor="#333333"
            android:gravity="center"
            android:paddingVertical="8dp" />

    </LinearLayout>

</ScrollView>
