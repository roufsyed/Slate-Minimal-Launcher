<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/settingsScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="40dp">

        <!-- ── Battery restriction banner ── -->
        <LinearLayout
            android:id="@+id/batteryBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#CC5500"
            android:paddingHorizontal="20dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:visibility="gone"
            android:tag="no_theme">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/batteryBannerTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Background activity restricted"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:tag="no_theme" />

                <TextView
                    android:id="@+id/btnBatteryDismiss"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#x2715;"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:padding="8dp"
                    android:tag="no_theme" />

            </LinearLayout>

            <TextView
                android:id="@+id/batteryBannerMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Notification highlight and screen lock may stop working."
                android:textColor="#FFD5A8"
                android:textSize="13sp"
                android:paddingTop="3dp"
                android:paddingBottom="10dp"
                android:lineSpacingMultiplier="1.35"
                android:tag="no_theme" />

            <TextView
                android:id="@+id/btnUnrestrict"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FIX THIS"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:tag="no_theme" />

        </LinearLayout>

        <!-- ── General ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="28dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/labelGeneral"
                style="@style/SectionLabel"
                android:text="General" />

            <!-- Double tap to lock screen -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="10dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/labelDoubleTap"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Double tap to lock screen"
                        android:textSize="17sp" />

                    <TextView
                        android:id="@+id/labelDoubleTapSub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Requires accessibility service permission"
                        android:textSize="13sp"
                        android:alpha="0.6" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchDoubleTap"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- Sort by usage toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="10dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sort by most used"
                        android:textSize="17sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Most launched apps appear first"
                        android:textSize="13sp"
                        android:alpha="0.6" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchSortByUsage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- Lock orientation toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="10dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lock screen rotation"
                        android:textSize="17sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Keep launcher in portrait"
                        android:textSize="13sp"
                        android:alpha="0.6" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchLockOrientation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- Notification highlight toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="10dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Notification highlight"
                        android:textSize="17sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Change app color when notification arrives"
                        android:textSize="13sp"
                        android:alpha="0.6" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchNotifColor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- Notification color sub-row (visible when notif highlight is on) -->
            <LinearLayout
                android:id="@+id/rowNotifHighlight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="10dp"
                android:paddingStart="16dp"
                android:visibility="gone"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Highlight color"
                    android:textSize="15sp" />

                <View
                    android:id="@+id/notifColorSwatch"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:id="@+id/notifColorValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Status bar toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="10dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hide status bar"
                        android:textSize="17sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Full-screen launcher, swipe down to peek"
                        android:textSize="13sp"
                        android:alpha="0.6" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchHideStatusBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- Default launcher row -->
            <LinearLayout
                android:id="@+id/rowDefaultLauncher"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="12dp"
                android:background="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/labelDefaultLauncher"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Set as default launcher"
                        android:textSize="17sp" />

                    <TextView
                        android:id="@+id/labelDefaultLauncherSub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Open system launcher picker"
                        android:textSize="13sp"
                        android:alpha="0.6" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="→"
                    android:textSize="17sp" />
            </LinearLayout>

        </LinearLayout>

        <View
            android:id="@+id/divider0"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="28dp"
            android:layout_marginEnd="28dp" />

        <!-- ── Text Size ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="28dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/labelTextSize"
                style="@style/SectionLabel"
                android:text="Text Size" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/labelMinimum"
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    android:text="Minimum"
                    android:textSize="17sp" />

                <SeekBar
                    android:id="@+id/minFontSeekBar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="12dp" />

                <TextView
                    android:id="@+id/minFontLabel"
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:gravity="end" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/labelMaximum"
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    android:text="Maximum"
                    android:textSize="17sp" />

                <SeekBar
                    android:id="@+id/maxFontSeekBar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="12dp" />

                <TextView
                    android:id="@+id/maxFontLabel"
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:gravity="end" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/labelLineSpacing"
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    android:text="Line gap"
                    android:textSize="17sp" />

                <SeekBar
                    android:id="@+id/lineSpacingSeekBar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="12dp" />

                <TextView
                    android:id="@+id/lineSpacingLabel"
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:gravity="end" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/labelWordSpacing"
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    android:text="Word gap"
                    android:textSize="17sp" />

                <SeekBar
                    android:id="@+id/wordSpacingSeekBar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="12dp" />

                <TextView
                    android:id="@+id/wordSpacingLabel"
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:gravity="end" />
            </LinearLayout>

        </LinearLayout>

        <View
            android:id="@+id/divider1"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="28dp"
            android:layout_marginEnd="28dp" />

        <!-- ── Typography ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="28dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/labelTypography"
                style="@style/SectionLabel"
                android:text="Typography" />

            <LinearLayout
                android:id="@+id/rowFont"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="12dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Font"
                    android:textSize="17sp" />

                <TextView
                    android:id="@+id/fontValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowWeight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="12dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Weight"
                    android:textSize="17sp" />

                <TextView
                    android:id="@+id/weightValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowAlignment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="12dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Alignment"
                    android:textSize="17sp" />

                <TextView
                    android:id="@+id/alignmentValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp" />
            </LinearLayout>

        </LinearLayout>

        <View
            android:id="@+id/divider1b"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="28dp"
            android:layout_marginEnd="28dp" />

        <!-- ── Colors ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="28dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/labelColors"
                style="@style/SectionLabel"
                android:text="Colors" />

            <!-- Background row — tap to open picker -->
            <LinearLayout
                android:id="@+id/rowBgColor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="12dp"
                android:layout_marginBottom="4dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:id="@+id/labelBg"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Background"
                    android:textSize="17sp" />

                <View
                    android:id="@+id/bgColorSwatch"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/bgColorDisplay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- App text row — tap to open picker -->
            <LinearLayout
                android:id="@+id/rowTextColor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="12dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:id="@+id/labelText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="App text"
                    android:textSize="17sp" />

                <View
                    android:id="@+id/textColorSwatch"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/textColorDisplay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Preset color combinations -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PRESETS"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.15"
                android:textStyle="bold"
                android:alpha="0.5"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/preset1"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Aa"
                    android:gravity="center"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/preset2"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Aa"
                    android:gravity="center"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/preset3"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Aa"
                    android:gravity="center"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/preset4"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="Aa"
                    android:gravity="center"
                    android:textSize="17sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Apply to lockscreen toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="10dp"
                android:layout_marginTop="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Apply to lockscreen"
                        android:textSize="17sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fills your lockscreen with the same solid color as the launcher background for a uniform look"
                        android:textSize="13sp"
                        android:alpha="0.6" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchSyncToLockscreen"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- Follow system theme toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="10dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Follow system theme"
                        android:textSize="17sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Switch colors with system dark mode"
                        android:textSize="13sp"
                        android:alpha="0.6" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchFollowSystemTheme"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

        </LinearLayout>

        <View
            android:id="@+id/divider4"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="28dp"
            android:layout_marginEnd="28dp" />

        <!-- ── Gestures ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="28dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/labelGestures"
                style="@style/SectionLabel"
                android:text="Gestures" />

            <!-- Directional gesture rows — populated programmatically -->
            <LinearLayout
                android:id="@+id/gesturesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>

        <View
            android:id="@+id/divider2"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="28dp"
            android:layout_marginEnd="28dp" />

        <!-- ── Search ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="28dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/labelSearch"
                style="@style/SectionLabel"
                android:text="Search" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="10dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/labelSearchToggle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Enable search"
                        android:textSize="17sp" />

                    <TextView
                        android:id="@+id/labelSearchSub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Swipe up to open search bar"
                        android:textSize="13sp"
                        android:alpha="0.6" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchSearch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="10dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/labelSearchOnHome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Show on home screen"
                        android:textSize="17sp" />

                    <TextView
                        android:id="@+id/labelSearchOnHomeSub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Keep search bar visible, closes with keyboard"
                        android:textSize="13sp"
                        android:alpha="0.6" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchSearchOnHome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- Position sub-row (visible when show-on-home is on) -->
            <LinearLayout
                android:id="@+id/rowSearchBarPosition"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="10dp"
                android:paddingStart="16dp"
                android:visibility="gone"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Position"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/searchBarPositionValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp" />
            </LinearLayout>

        </LinearLayout>

        <View
            android:id="@+id/divider3"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="28dp"
            android:layout_marginEnd="28dp" />

        <!-- ── Backup ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="28dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/labelBackup"
                style="@style/SectionLabel"
                android:text="Backup" />

            <LinearLayout
                android:id="@+id/rowExportBackup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="14dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Export settings"
                    android:textSize="17sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="→"
                    android:textSize="17sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowImportBackup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="14dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Import settings"
                    android:textSize="17sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="→"
                    android:textSize="17sp" />
            </LinearLayout>

        </LinearLayout>

        <View
            android:id="@+id/divider5"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="28dp"
            android:layout_marginEnd="28dp" />

        <!-- ── About ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="28dp"
            android:paddingBottom="40dp">

            <TextView
                style="@style/SectionLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="About" />

            <!-- GitHub row -->
            <LinearLayout
                android:id="@+id/rowGithub"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="12dp"
                android:background="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Source &amp; License"
                        android:textSize="17sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="github.com/roufsyed/Slate-Minimal-Launcher"
                        android:textSize="13sp"
                        android:alpha="0.6" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="→"
                    android:textSize="17sp" />
            </LinearLayout>

            <!-- Version (read-only) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Version"
                    android:textSize="17sp" />

                <TextView
                    android:id="@+id/labelAppVersion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
