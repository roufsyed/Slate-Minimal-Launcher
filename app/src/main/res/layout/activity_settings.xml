<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/settingsScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="40dp">

        <!-- ── Text Size ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="28dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/labelTextSize"
                style="@style/SectionLabel"
                android:text="Text Size" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/labelMinimum"
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    android:text="Minimum"
                    android:textSize="17sp" />

                <SeekBar
                    android:id="@+id/minFontSeekBar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="12dp" />

                <TextView
                    android:id="@+id/minFontLabel"
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:gravity="end" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/labelMaximum"
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    android:text="Maximum"
                    android:textSize="17sp" />

                <SeekBar
                    android:id="@+id/maxFontSeekBar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="12dp" />

                <TextView
                    android:id="@+id/maxFontLabel"
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:gravity="end" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/labelLineSpacing"
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    android:text="Line gap"
                    android:textSize="17sp" />

                <SeekBar
                    android:id="@+id/lineSpacingSeekBar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="12dp" />

                <TextView
                    android:id="@+id/lineSpacingLabel"
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:gravity="end" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/labelWordSpacing"
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    android:text="Word gap"
                    android:textSize="17sp" />

                <SeekBar
                    android:id="@+id/wordSpacingSeekBar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="12dp" />

                <TextView
                    android:id="@+id/wordSpacingLabel"
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:gravity="end" />
            </LinearLayout>

        </LinearLayout>

        <View
            android:id="@+id/divider1"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="28dp"
            android:layout_marginEnd="28dp" />

        <!-- ── Typography ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="28dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/labelTypography"
                style="@style/SectionLabel"
                android:text="Typography" />

            <LinearLayout
                android:id="@+id/rowFont"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="12dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Font"
                    android:textSize="17sp" />

                <TextView
                    android:id="@+id/fontValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowWeight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="12dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Weight"
                    android:textSize="17sp" />

                <TextView
                    android:id="@+id/weightValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp" />
            </LinearLayout>

        </LinearLayout>

        <View
            android:id="@+id/divider1b"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="28dp"
            android:layout_marginEnd="28dp" />

        <!-- ── Colors ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="28dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/labelColors"
                style="@style/SectionLabel"
                android:text="Colors" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/labelBg"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="Background"
                    android:textSize="17sp" />

                <View
                    android:id="@+id/bgColorSwatch"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="12dp" />

                <EditText
                    android:id="@+id/bgColorInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="#000000"
                    android:inputType="text"
                    android:maxLines="1"
                    android:textSize="16sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/labelText"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="App text"
                    android:textSize="17sp" />

                <View
                    android:id="@+id/textColorSwatch"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="12dp" />

                <EditText
                    android:id="@+id/textColorInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="#808080"
                    android:inputType="text"
                    android:maxLines="1"
                    android:textSize="16sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

        </LinearLayout>

        <View
            android:id="@+id/divider4"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="28dp"
            android:layout_marginEnd="28dp" />

        <!-- ── Gestures ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="28dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/labelGestures"
                style="@style/SectionLabel"
                android:text="Gestures" />

            <!-- Double tap row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="10dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/labelDoubleTap"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Double tap to lock screen"
                        android:textSize="17sp" />

                    <TextView
                        android:id="@+id/labelDoubleTapSub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Requires device admin permission"
                        android:textSize="13sp"
                        android:alpha="0.6" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchDoubleTap"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- Directional gesture rows — populated programmatically -->
            <LinearLayout
                android:id="@+id/gesturesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>

        <View
            android:id="@+id/divider2"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="28dp"
            android:layout_marginEnd="28dp" />

        <!-- ── Search ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="28dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/labelSearch"
                style="@style/SectionLabel"
                android:text="Search" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="10dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/labelSearchToggle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Enable search"
                        android:textSize="17sp" />

                    <TextView
                        android:id="@+id/labelSearchSub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Swipe up to open search bar"
                        android:textSize="13sp"
                        android:alpha="0.6" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchSearch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="10dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/labelSearchOnHome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Show on home screen"
                        android:textSize="17sp" />

                    <TextView
                        android:id="@+id/labelSearchOnHomeSub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Keep search bar visible, closes with keyboard"
                        android:textSize="13sp"
                        android:alpha="0.6" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchSearchOnHome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

        </LinearLayout>

        <View
            android:id="@+id/divider3"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="28dp"
            android:layout_marginEnd="28dp" />

        <!-- ── Backup ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="28dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/labelBackup"
                style="@style/SectionLabel"
                android:text="Backup" />

            <LinearLayout
                android:id="@+id/rowExportBackup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="14dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Export settings"
                    android:textSize="17sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="→"
                    android:textSize="17sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowImportBackup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="14dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Import settings"
                    android:textSize="17sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="→"
                    android:textSize="17sp" />
            </LinearLayout>

        </LinearLayout>

        <View
            android:id="@+id/divider6"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="28dp"
            android:layout_marginEnd="28dp" />

        <!-- ── General ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="28dp"
            android:paddingBottom="40dp">

            <TextView
                android:id="@+id/labelGeneral"
                style="@style/SectionLabel"
                android:text="General" />

            <!-- Sort by usage toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="10dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sort by most used"
                        android:textSize="17sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Most launched apps appear first"
                        android:textSize="13sp"
                        android:alpha="0.6" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchSortByUsage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- Lock orientation toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="10dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lock screen rotation"
                        android:textSize="17sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Keep launcher in portrait"
                        android:textSize="13sp"
                        android:alpha="0.6" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchLockOrientation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- Status bar toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="10dp"
                android:layout_marginBottom="4dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hide status bar"
                        android:textSize="17sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Full-screen launcher, swipe down to peek"
                        android:textSize="13sp"
                        android:alpha="0.6" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchHideStatusBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowDefaultLauncher"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="12dp"
                android:background="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/labelDefaultLauncher"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Set as default launcher"
                        android:textSize="17sp" />

                    <TextView
                        android:id="@+id/labelDefaultLauncherSub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Open system launcher picker"
                        android:textSize="13sp"
                        android:alpha="0.6" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="→"
                    android:textSize="17sp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
